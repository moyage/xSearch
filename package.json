{
  "name": "xsearch",
  "version": "1.0.0",
  "description": "xSearch - A standard skill library for enhancing agent systems with advanced search capabilities.",
  "main": "dist/skills/xsearchSkill.js",
  "types": "dist/skills/xsearchSkill.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "build:mcp": "esbuild src/mcp-server.ts --bundle --platform=node --outfile=dist/mcp.js",
    "start:mcp": "node dist/mcp.js"
  },
  "keywords": [
    "openclaw",
    "skill",
    "search",
    "scraper",
    "web-crawler",
    "data-extraction"
  ],
  "author": "moyage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moyage/xSearch.git"
  },
  "bugs": {
    "url": "https://github.com/moyage/xSearch/issues"
  },
  "homepage": "https://github.com/moyage/xSearch#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "skillName": "xsearch",
    "displayName": "xSearch",
    "description": "A standard skill library for enhancing agent systems with advanced search capabilities.",
    "category": "data-collection",
    "entryPoint": "dist/skills/xsearchSkill.js",
    "permissions": [
      "network",
      "filesystem"
    ],
    "config": {
      "defaultProvider": {
        "type": "string",
        "description": "Default search provider (tavily, apiHijacker, or browser)",
        "default": "tavily",
        "options": [
          "tavily",
          "apiHijacker",
          "browser"
        ]
      },
      "tavilyApiKey": {
        "type": "string",
        "description": "Tavily API Key (Optional)",
        "required": false
      },
      "apiHijacker": {
        "type": "object",
        "description": "Configuration for API Hijacker mode",
        "required": false
      }
    },
    "mcpServer": {
      "command": "node",
      "args": [
        "dist/mcp.js"
      ],
      "description": "xSearch MCP Server - Advanced search capabilities for AI agents",
      "tools": [
        {
          "name": "xsearch_search",
          "description": "Standard search with configurable provider and options"
        },
        {
          "name": "xsearch_batch_search",
          "description": "Execute multiple search queries in parallel"
        }
      ]
    },
    "mcpServers": {
      "xsearch": {
        "command": "node",
        "args": [
          "${__dirname}/dist/mcp.js"
        ],
        "env": {}
      }
    }
  }
}
{
  "name": "xsearch",
  "version": "1.0.0",
  "description": "XSearch - 智能搜索增强技能，提供强大的外部信息搜索、检索、分析和可视化能力",
  "main": "dist/skills/xsearchSkill.js",
  "types": "dist/skills/xsearchSkill.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "skill",
    "search",
    "scraper",
    "web-crawler",
    "data-extraction"
  ],
  "author": "moyage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moyage/xSearch.git"
  },
  "bugs": {
    "url": "https://github.com/moyage/xSearch/issues"
  },
  "homepage": "https://github.com/moyage/xSearch#readme",
  "dependencies": {
    "playwright": "^1.40.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "skillName": "xsearch",
    "displayName": "XSearch 智能搜索",
    "description": "智能搜索增强技能，支持多源搜索、浏览器自动化、内容提取和数据分析",
    "category": "data-collection",
    "entryPoint": "dist/skills/xsearchSkill.js",
    "permissions": [
      "network",
      "filesystem"
    ],
    "config": {
      "tavilyApiKey": {
        "type": "string",
        "description": "Tavily API Key (可选)",
        "required": false
      },
      "defaultProvider": {
        "type": "string",
        "description": "默认搜索提供商",
        "default": "tavily",
        "options": ["tavily", "browser", "hybrid"]
      }
    }
  }
}

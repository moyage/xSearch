{
  "name": "xsearch",
  "version": "6.0.0",
  "description": "XSearch V6 (Protocol Hijacker) - Next-generation API/MCP hijacking search engine for AI Agents.",
  "main": "dist/skills/xsearchSkill.js",
  "types": "dist/skills/xsearchSkill.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "openclaw",
    "skill",
    "search",
    "scraper",
    "web-crawler",
    "data-extraction"
  ],
  "author": "moyage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moyage/xSearch.git"
  },
  "bugs": {
    "url": "https://github.com/moyage/xSearch/issues"
  },
  "homepage": "https://github.com/moyage/xSearch#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.0",
    "fintec-agent-laws": "file:../labs-teamwork-spec",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "skillName": "xsearch",
    "displayName": "XSearch V6 API Hijacker",
    "description": "Zero-DOM-dependency, high-speed API and MCP protocol hijacking search engine. Designed to bypass Cloudflare and paginate infinitely via native APIs.",
    "category": "data-collection",
    "entryPoint": "dist/skills/xsearchSkill.js",
    "permissions": [
      "network",
      "filesystem"
    ],
    "config": {
      "defaultProvider": {
        "type": "string",
        "description": "Default search provider (apiHijacker or tavily)",
        "default": "apiHijacker",
        "options": [
          "apiHijacker",
          "tavily",
          "browser"
        ]
      },
      "tavilyApiKey": {
        "type": "string",
        "description": "Tavily API Key (Optional)",
        "required": false
      },
      "apiHijacker": {
        "type": "object",
        "description": "Configuration for the Protocol Hijacker mode (Base URL, Pagination Rules)",
        "required": false
      }
    }
  }
}